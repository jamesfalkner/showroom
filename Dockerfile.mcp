# Dockerfile for MCP Server (Kubernetes MCP Server for Workshop)
# Uses the official kubernetes-mcp-server npm package

FROM registry.access.redhat.com/ubi10/nodejs-22-minimal:latest

# Set working directory to user home (standard for UBI Node.js images)
WORKDIR $HOME

# Set environment variables
ENV MCP_SERVER_HOST=0.0.0.0
ENV MCP_SERVER_PORT=8080

EXPOSE 8080

RUN npm install  kubernetes-mcp-server@latest

# Run the kubernetes-mcp-server using the installed binary
CMD ["node_modules/.bin/kubernetes-mcp-server", "--port", "8080", "--log-level", "9"]