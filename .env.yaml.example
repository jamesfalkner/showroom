# Environment configuration for Showroom AI Assistant
# Copy this file to .env.yaml and replace the dummy values with your actual credentials

# OpenAI API Configuration
# Get your API key from https://platform.openai.com/api-keys
llm_api_key: "sk-proj-your-openai-api-key-here"

# GitLab Personal Access Token (optional, for GitLab MCP server)
# Create at https://gitlab.com/-/profile/personal_access_tokens
# Requires: api, read_repository, write_repository scopes
gitlab_personal_access_token: "glpat-your-gitlab-token-here"

# Note: LLM configuration (API URL, model, etc.) is set via environment variables
# when running the container locally, not in this file.
#
# For local development examples:
#
# For OpenAI (default):
#   -e LLM_API_URL="https://api.openai.com/v1/chat/completions"
#   -e LLM_MODEL="gpt-4"
#
# For Azure OpenAI:
#   -e LLM_API_URL="https://your-resource.openai.azure.com/openai/deployments/your-model/chat/completions?api-version=2023-05-15"
#   -e LLM_MODEL="gpt-4"
#
# For Local Ollama:
#   -e LLM_API_URL="http://host.docker.internal:11434/v1/chat/completions"
#   -e LLM_MODEL="llama2"
#   -e LLM_API_KEY="dummy"
#
# Note: When running on OpenShift, LLM and MCP configuration is managed through
# ConfigMaps in k8s-backend/configmap.yaml. The deploy.sh script automatically
# reads API keys from this .env.yaml file and updates the OpenShift secrets.